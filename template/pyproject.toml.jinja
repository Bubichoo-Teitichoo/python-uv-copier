[build-system]
requires = ["uv_build>=0.11.14,<0.12"]
build-backend = "uv_build"

[project]
name = "{{ slug }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
license = { text = "MIT" }
authors = [
    {name = "{{ user }}", email = "{{ email }}"},
]
requires-python = ">=3.10,<3.14"
dependencies = [
]

[project.scripts]
{{slug}} = "{{snake}}.__main__:main"

[dependency-groups]
dev = [
    "ruff>=0.8.0",
    "mypy>=1.15.0",
    "pre-commit>=4.0.0",
]
test = [
    "pytest>=8.1.1",
    "pytest-cov>=5.0.0",
]
docs = [
    "mkdocs>=1.5.3",
    "mike>=2.0.0",
    "mkdocs-material>=9.5.18",
    "mkdocstrings[python]>=0.24.3",
    "mkdocs-same-dir>=0.1.3",
]

[tool.git-changelog]
convention = "conventional"
provider = "github"
output = "CHANGELOG.md"

[tool.commitizen]
version_provider="pep621"
update_changelog_on_bump=false

