[build-system]
requires = ["uv_build>=0.11.14,<0.12"]
build-backend = "uv_build"

[project]
name = "{{ slug }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
license = { text = "MIT" }
authors = [
    {name = "{{ user }}", email = "{{ email }}"},
]
requires-python = ">=3.10,<3.14"
dependencies = [
]

[project.scripts]
{{slug}} = "{{snake}}.__main__:main"

[dependency-groups]
dev = [
]
test = [
    "pytest~=9.0.0",
    "pytest-mock~=3.15.0",
    "pytest-cov>=7.1.0",
]
docs = [
    "properdocs~=1.6.0",
    "mike~=2.2.0",
    "mkdocs-material~=9.7.0",
    "mkdocstrings[python]~=1.0.0",
    "mkdocs-same-dir~=0.1.0",
]

[tool.git-changelog]
convention = "conventional"
provider = "github"
output = "CHANGELOG.md"

[tool.commitizen]
version_provider="pep621"
update_changelog_on_bump=false

